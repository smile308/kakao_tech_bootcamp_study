JWT_SECRET=replace-this-with-a-long-random-secret-key-at-least-32-characters
JWT_ACCESS_EXPIRATION_MILLIS=600000
JWT_REFRESH_EXPIRATION_MILLIS=10800000
JWT_REFRESH_SESSION_CLEANUP_INTERVAL_MILLIS=3600000
# 로컬 HTTP에서는 false, HTTPS 운영 배포 환경에서는 true로 설정한다.
JWT_REFRESH_COOKIE_SECURE=false
CORS_ALLOWED_ORIGINS=http://localhost:5500,http://127.0.0.1:5500,http://localhost:5173,http://127.0.0.1:5173
